# Copy to .env for local runs. NEVER commit the real .env.
# In GitHub Actions these come from repo Secrets/Variables instead.

# Supabase project (Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...                # public, safe to ship to the browser (RLS = read-only)
SUPABASE_SERVICE_KEY=eyJ...             # SECRET — server-side writes only, never in the client

# Where the news site is published (no trailing slash)
SITE_URL=https://news.xsonomy.com
HOME_URL=https://xsonomy.com/
# CNAME=news.xsonomy.com                # uncomment to emit public/CNAME for a custom domain

# Tuning (optional)
INGEST_MAX_AGE_DAYS=14
PAGE_SIZE=24
